from flask import Flask, request, render_template_string
import PyPDF2

app = Flask(__name__)

html = """
<!DOCTYPE html>
<html>
<head>
    <title>ResumeLens AI</title>
    <style>
        body {
            font-family: Arial;
            text-align: center;
            background-color: #f4f6f9;
            margin-top: 50px;
        }
        h1 { color: #333; }
        form { margin-top: 20px; }
        input[type="file"] {
            padding: 10px;
            border-radius: 5px;
        }
        button {
            padding: 10px 20px;
            background-color: #007BFF;
            border: none;
            color: white;
            border-radius: 5px;
            cursor: pointer;
        }
        button:hover { background-color: #0056b3; }
        .result {
            margin-top: 30px;
            font-size: 18px;
            width: 60%;
            margin-left: auto;
            margin-right: auto;
            background: white;
            padding: 20px;
            border-radius: 10px;
            box-shadow: 0px 0px 10px rgba(0,0,0,0.1);
        }
        .score { font-size: 24px; font-weight: bold; color: green; }
        .suggest { color: red; margin-top: 10px; }
    </style>
</head>
<body>

    <h1>📄 ResumeLens AI</h1>
    <p>Upload your resume and get AI-based analysis</p>

    <form method="POST" enctype="multipart/form-data">
        <input type="file" name="resume" required><br><br>
        <button type="submit">Analyze Resume</button>
    </form>

    {% if score %}
    <div class="result">
        <div class="score">Score: {{ score }}/100</div>
        <p><strong>Detected Skills:</strong> {{ skills }}</p>
        <p class="suggest"><strong>Suggestions:</strong> {{ suggestion }}</p>
    </div>
    {% endif %}

</body>
</html>
"""

# Simple skill keywords
skills_db = ["python", "java", "c", "sql", "html", "css", "javascript",
             "react", "node", "django", "flask", "dbms", "machine learning"]

def extract_text(file):
    text = ""
    if file.filename.endswith(".pdf"):
        reader = PyPDF2.PdfReader(file)
        for page in reader.pages:
            text += page.extract_text()
    else:
        text = file.read().decode("utf-8")
    return text.lower()

@app.route("/", methods=["GET", "POST"])
def home():
    score = None
    skills_found = []
    suggestion = ""

    if request.method == "POST":
        file = request.files["resume"]
        text = extract_text(file)

        for skill in skills_db:
            if skill in text:
                skills_found.append(skill)

        score = min(len(skills_found) * 10, 100)

        if score < 50:
            suggestion = "Add more technical skills and projects."
        elif score < 80:
            suggestion = "Good resume, but improve formatting and add achievements."
        else:
            suggestion = "Excellent resume!"

    return render_template_string(
        html,
        score=score,
        skills=", ".join(skills_found),
        suggestion=suggestion
    )

if __name__ == "__main__":
    app.run(debug=True)